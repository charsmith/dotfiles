# Login shells source ~/.bash_profile instead of ~/.bashrc.
# Delegate to ~/.bashrc so both shell types get the same config.
[[ -f ~/.bashrc ]] && source ~/.bashrc

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/charsmith/Downloads/google-cloud-sdk/path.bash.inc' ]; then . '/Users/charsmith/Downloads/google-cloud-sdk/path.bash.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/charsmith/Downloads/google-cloud-sdk/completion.bash.inc' ]; then . '/Users/charsmith/Downloads/google-cloud-sdk/completion.bash.inc'; fi
