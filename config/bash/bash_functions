# Bash utility functions.

# mkdir + cd in one step.
mkcd() {
  [[ $# -eq 1 ]] || { echo "usage: mkcd <dir>" >&2; return 2; }
  mkdir -p -- "$1" && cd -- "$1"
}

# Extract most common archive types by sniffing the extension.
extract() {
  [[ $# -eq 1 && -f $1 ]] || { echo "usage: extract <archive>" >&2; return 2; }
  case "$1" in
    *.tar.bz2|*.tbz2) tar -xjf "$1" ;;
    *.tar.gz|*.tgz)   tar -xzf "$1" ;;
    *.tar.xz|*.txz)   tar -xJf "$1" ;;
    *.tar.zst)        tar --zstd -xf "$1" ;;
    *.tar)            tar -xf  "$1" ;;
    *.bz2)            bunzip2  "$1" ;;
    *.gz)             gunzip   "$1" ;;
    *.xz)             unxz     "$1" ;;
    *.zip)            unzip    "$1" ;;
    *.7z)             7z x     "$1" ;;
    *.rar)            unrar x  "$1" ;;
    *) echo "extract: don't know how to handle '$1'" >&2; return 1 ;;
  esac
}

# Send a WezTerm toast notification, wrapping for tmux passthrough when needed.
notify() {
  local msg="${1:-Done}"
  if [[ -n "$TMUX" ]]; then
    printf "\ePtmux;\e\e]9;%s\a\e\\" "$msg"
  else
    printf "\e]9;%s\a" "$msg"
  fi
}

# wezterm imgcat sends DA/size terminal queries to detect capabilities.
# In tmux the responses (?1;2;4c, 6;NNt) land in the tty input buffer and
# appear at the prompt as if typed. We drain them in PROMPT_COMMAND instead
# of inline — by the time PROMPT_COMMAND runs the responses have already
# arrived, so the read is instant and never races with real user input.
_IMGCAT_PENDING_DRAIN=0
imgcat() {
  wezterm imgcat "$@"
  [[ -n "$TMUX" ]] && _IMGCAT_PENDING_DRAIN=1
}
_imgcat_drain() {
  [[ $_IMGCAT_PENDING_DRAIN -eq 1 ]] || return
  _IMGCAT_PENDING_DRAIN=0
  local _
  IFS= read -t 0.1 -rs -n 64 _ </dev/tty 2>/dev/null || true
}
[[ "$PROMPT_COMMAND" == *_imgcat_drain* ]] || PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND; }_imgcat_drain"

# Install Claude Code skills from a GitHub Enterprise blob URL.
# Usage: aitc skill add https://github.netflix.net/owner/repo/blob/branch/path/SKILL.md
aitc() {
  if [[ "$1 $2" != "skill add" ]]; then
    echo "usage: aitc skill add <github-blob-url>" >&2; return 1
  fi
  local url="$3"
  [[ -n "$url" ]] || { echo "usage: aitc skill add <github-blob-url>" >&2; return 1; }

  # Parse: https://<hostname>/<owner>/<repo>/blob/<branch>/<path>
  local hostname owner repo path
  hostname=$(awk -F/ '{print $3}' <<< "$url")
  owner=$(awk   -F/ '{print $4}' <<< "$url")
  repo=$(awk    -F/ '{print $5}' <<< "$url")
  path=$(awk    -F/ '{for(i=8;i<=NF;i++) printf "%s%s",$i,(i<NF?"/":""); print ""}' <<< "$url")

  [[ -n "$hostname" && -n "$owner" && -n "$repo" && -n "$path" ]] || {
    echo "aitc: couldn't parse URL '$url'" >&2; return 1
  }

  local content
  content=$(gh api --hostname "$hostname" "/repos/$owner/$repo/contents/$path" \
    --jq '.content' 2>/dev/null | base64 -d)
  [[ -n "$content" ]] || { echo "aitc: failed to fetch $url" >&2; return 1; }

  local name
  name=$(awk '/^name:/{print $2; exit}' <<< "$content")
  [[ -n "$name" ]] || { echo "aitc: no 'name:' found in skill frontmatter" >&2; return 1; }

  local dest="$HOME/.claude/skills/$name"
  mkdir -p "$dest"
  printf '%s\n' "$content" > "$dest/SKILL.md"
  echo "aitc: installed '$name' → $dest/SKILL.md"
}

# Open the current git repo on GitHub/GHE in the browser.
gho() {
  local remote
  remote="$(git remote get-url origin 2>/dev/null)" || { echo "gho: not a git repo or no origin" >&2; return 1; }
  remote="${remote%.git}"
  # Convert SSH remote (any host) to HTTPS: git@host:owner/repo → https://host/owner/repo
  if [[ "$remote" == git@* ]]; then
    remote="${remote#git@}"
    remote="https://${remote/://}"
  fi
  if command -v open >/dev/null 2>&1; then open "$remote"; else xdg-open "$remote"; fi
}
