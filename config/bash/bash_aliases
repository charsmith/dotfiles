# Prefer eza when available; fall back to coreutils ls.
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first --icons=auto'
  alias ll='eza -lh --group-directories-first --git --icons=auto'
  alias la='eza -a --group-directories-first --icons=auto'
  alias lal='eza -lah --group-directories-first --git --icons=auto'
  alias l='eza --group-directories-first --icons=auto'
  alias lt='eza --tree --level=2 --group-directories-first --icons=auto'
elif ls --color=auto / >/dev/null 2>&1; then
  # GNU ls (Linux): supports --color and --group-directories-first
  alias ls='ls --color=auto -pF --group-directories-first'
  alias ll='ls -lh --color=auto --group-directories-first'
  alias la='ls -A --color=auto --group-directories-first'
  alias lal='ls -lAh --color=auto --group-directories-first'
  alias l='ls -CF --color=auto --group-directories-first'
else
  # BSD ls (macOS fallback): -G for color, no group-directories-first
  alias ls='ls -GpF'
  alias ll='ls -lh'
  alias la='ls -A'
  alias lal='ls -lAh'
  alias l='ls -CF'
fi

alias vi='nvim'
command -v bat >/dev/null 2>&1 && alias cat='bat --paging=never --style=plain'
