# Prefer eza when available; fall back to coreutils ls.
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first'
  alias ll='eza -lh --group-directories-first --git'
  alias la='eza -a --group-directories-first'
  alias lal='eza -lah --group-directories-first --git'
  alias l='eza --group-directories-first'
  alias lt='eza --tree --level=2 --group-directories-first'
else
  alias ls='ls -GpF'
  alias ll='ls -lh'
  alias la='ls -A'
  alias lal='ls -Alh'
  alias l='ls -CF'
fi

alias vi='nvim'
command -v bat >/dev/null 2>&1 && alias cat='bat --paging=never --style=plain'

# Only alias cd -> z when zoxide is installed (resolved at command time)
command -v zoxide >/dev/null 2>&1 && alias cd='z'
