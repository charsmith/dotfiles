#!/bin/bash

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# History settings
export HISTCONTROL=ignoreboth
export HISTIGNORE="fg:exit:clear:history"
export HISTSIZE=100000
export HISTFILESIZE=100000
export HISTTIMEFORMAT="%F %T "

# Claude is silly
export CLAUDE_CODE_TMUX_TRUECOLOR=1

# Shell options
shopt -s checkwinsize
shopt -s cdspell
shopt -s histappend
set -o vi

# Environment variables
export GDK_NATIVE_WINDOWS=1
if command -v nvim >/dev/null 2>&1; then
  export EDITOR='nvim'
  export VISUAL='nvim'
  export MANPAGER='nvim +Man!'
else
  export MANPAGER='less -Xq'
fi
export PAGER='less -Xq'
#export NEWT_CONFIGS_DIR=~/code/nflx/newt-configs

# Path modifications
export PYENV_ROOT="$HOME/.pyenv"
[[ -d "$PYENV_ROOT/bin" ]] && export PATH="$PYENV_ROOT/bin:$PATH"
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

if command -v pyenv >/dev/null; then
  eval "$(pyenv init -)"
fi

# Terminal color settings
setup_terminal_colors() {
  local TMP_TERM=$TERM
  SCREEN_COLORS=$(tput colors 2>/dev/null)
  if [[ -z $SCREEN_COLORS ]]; then
    export TERM=xterm-256color
    SCREEN_COLORS=$(tput colors 2>/dev/null)
  fi
  if [[ -z $SCREEN_COLORS ]]; then
    export TERM=$TMP_TERM
  fi
  # Declare truecolor support for terminals that don't set COLORTERM themselves
  if [[ -z $COLORTERM ]]; then
    # WezTerm sets TERM_PROGRAM; Windows Terminal sets WT_SESSION
    if [[ $TERM_PROGRAM == "WezTerm" || -n $WT_SESSION ]]; then
      export COLORTERM=truecolor
    fi
  fi
}
setup_terminal_colors

# Starship prompt
eval "$(starship init bash)"

# Homebrew (Apple Silicon vs Intel)
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Less settings
[[ -x /usr/bin/lesspipe ]] && eval "$(lesspipe)"
[[ -x /usr/local/bin/lesspipe.sh ]] && eval "$(/usr/local/bin/lesspipe.sh)"
[[ -x /opt/homebrew/bin/lesspipe.sh ]] && eval "$(/opt/homebrew/bin/lesspipe.sh)"

# Source additional configuration files
source_if_exists() {
  [[ -f $1 ]] && source "$1"
}

source_if_exists ~/.config/bash/bash_functions
source_if_exists ~/.config/bash/bash_aliases

# bash-completion@2 (Homebrew) ships its loader under profile.d/. Set
# BASH_COMPLETION_COMPAT_DIR so v1-style completions in /etc/bash_completion.d
# are still picked up.
export BASH_COMPLETION_COMPAT_DIR="/etc/bash_completion.d"
source_if_exists /opt/homebrew/etc/profile.d/bash_completion.sh
source_if_exists /usr/local/etc/profile.d/bash_completion.sh
source_if_exists /etc/bash_completion

# Source the local file matching the current OS
source_locals() {
  local SCRIPT_DIR="$(dirname "${BASH_SOURCE[0]}")"
  local os
  case "$(uname)" in
    Darwin) os=macos ;;
    Linux) os=linux ;;
    MINGW*|MSYS*|CYGWIN*) os=windows ;;
    *) return ;;
  esac
  source_if_exists "$SCRIPT_DIR/locals/$os.sh"
}
source_locals

# NVM setup
export NVM_DIR="$HOME/.nvm"
source_if_exists "$NVM_DIR/nvm.sh"
source_if_exists "$NVM_DIR/bash_completion"

# Initialize zoxide if available (the `cd` -> `z` alias lives in bash_aliases)
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init bash)"
fi

# direnv: per-directory env. Loads .envrc on cd into an allowed dir.
if command -v direnv &>/dev/null; then
  eval "$(direnv hook bash)"
fi

# fzf: Ctrl-R history search, Ctrl-T file picker, Alt-C dir picker.
# Prefer fd for traversal (respects .gitignore) and bat for previews.
if command -v fzf &>/dev/null; then
  eval "$(fzf --bash 2>/dev/null)"
  if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
  fi
  if command -v bat &>/dev/null; then
    export FZF_CTRL_T_OPTS="--preview 'bat --style=numbers --color=always --line-range :200 {}'"
  fi
fi

source_if_exists ~/.local/bin/env
